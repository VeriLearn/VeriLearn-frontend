{
  "title": "VeriLearn k6 Load Testing",
  "uid": "verilearn-k6",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "http_req_duration",
          "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval), \"scenario\" fill(null)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (reqs/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "http_reqs",
          "query": "SELECT derivative(sum(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval), \"scenario\" fill(null)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Virtual Users",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "vus",
          "query": "SELECT mean(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval), \"scenario\" fill(null)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "failed_requests",
          "query": "SELECT sum(\"value\") FROM \"failed_requests\" WHERE $timeFilter GROUP BY time($__interval), \"page\" fill(null)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Page Load Time by Page (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "page_load_time",
          "query": "SELECT percentile(\"value\", 95) FROM \"page_load_time\" WHERE $timeFilter GROUP BY time($__interval), \"page\" fill(null)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Success Rate",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "measurement": "success_rate",
          "query": "SELECT mean(\"value\") * 100 FROM \"success_rate\" WHERE $timeFilter",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizValue": 0,
        "maxVizValue": 100
      }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
